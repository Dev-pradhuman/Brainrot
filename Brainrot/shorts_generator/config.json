  "bulk": {
    "daily_cap": 10,
    "min_interval_sec": 300,
    "max_interval_sec": 900
  },

  "schedule": {
    "enabled": false,
    "timezone": "America/New_York",
    "per_day": 1,
    "best_days_only": false,
    "_comment": "When enabled, uploads use YouTube's publishAt to go live in the target country's Shorts prime time (evenings; Fri/Sat/Thu strongest) instead of publishing immediately. timezone = your target AUDIENCE's zone, not your own. per_day = how many Shorts to schedule per day. best_days_only = restrict to Fri/Sat/Thu."
  },

  "import": {
    "transcription_engine": "deepgram",
    "deepgram": {
      "api_key": "${DEEPGRAM_API_KEY}",
      "model": "nova-2"
    },
    "whisper": {
      "model_size": "base",
      "device": "cpu",
      "compute_type": "int8"
    },
    "min_clip_sec": 30,
    "max_clip_sec": 90,
    "max_candidates": 10,
    "burn_captions": true,
    "metadata_category": "reddit"
  },

  "games": {
    "api_key": "${YOUTUBE_API_KEY}",
    "category_id": "20",
    "regions": ["US"],
    "channels": [
      "@MrBeastGaming",
      "@DanTDM",
      "@Jacksepticeye",
      "@Markiplier",
