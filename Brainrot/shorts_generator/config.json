{
  "output_dir": "../output",
  "resolution": [1080, 1920],
  "fps": 30,
  "target_words": 300,
  "max_seconds": 150,

  "background_dir": "../Background_videos",
  "tts_engine": "edge",
  "edge_voice": "en-US-AvaMultilingualNeural",
  "edge_rate": "-4%",

  "elevenlabs": {
    "api_key": "${ELEVENLABS_API_KEY}",
    "voice_id": "21m00Tcm4TlvDq8ikWAM",
    "model_id": "eleven_multilingual_v2",
    "stability": 0.45,
