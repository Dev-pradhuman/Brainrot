  "caption": {
    "font": "Anton",
    "fonts_dir": "fonts",
    "font_size": 96,
    "bold": 0,
    "primary_color": "&H00FFFFFF",
    "highlight_color": "&H0000F0FF",
    "outline_color": "&H00000000",
    "outline": 5,
    "shadow": 1,
    "alignment": 5,
    "margin_v": 0,
    "max_words": 3,
    "max_caption_ms": 1200,
    "glow_blur": 6,
    "uppercase": true
  },

