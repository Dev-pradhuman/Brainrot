# Copy this file to `.env` in the same directory and fill in your keys.
# `.env` is gitignored — never commit real keys.
# config.json reads these via ${VAR} placeholders (see generate.py::_resolve_env).

# ---------------------------------------------------------------------------
# Groq — free tier. Required.
# Writes the scripts for the from-scratch niches (generate.py) and ranks the
# viral-moment clip candidates for imported videos (import_clip.py).
# Get one at: https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# YouTube Data API v3 — free quota. Optional.
# Read-only public data, used by the "games" niche to find trending gaming
# videos (games.py) and by the background downloader's search.
# Not needed for uploads — those use OAuth via client_secret.json instead.
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------------------------------------------------------------------------
# Deepgram — speech-to-text for the "Import Long Video" path (import_clip.py).
# Needed only while config.json has import.transcription_engine = "deepgram"
# (the default). Free tier is $200 of credit with no card; nova-2 pre-recorded
# bills $0.0043/min, so that's roughly 775 hours of audio before you'd pay.
# To run free forever instead: `pip install faster-whisper` and set
# import.transcription_engine to "whisper" in config.json.
# Get one at: https://console.deepgram.com/
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ---------------------------------------------------------------------------
# ElevenLabs — paid TTS. Optional and unused by default.
# The pipeline ships with tts_engine = "edge" (free Microsoft edge-tts), so
# leave this blank unless you deliberately switch engines.
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
